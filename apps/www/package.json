{
  "name": "www",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "dotenvx decrypt -f ../../.env --stdout > .env.local && node -e \"const fs=require('node:fs'); const p='../../.env.local'; if (fs.existsSync(p)) fs.appendFileSync('.env.local', fs.readFileSync(p));\" && pnpm cf-typegen && pnpm with-env-local vp dev",
    "prebuild:local": "pnpm with-env-local jiti ./scripts/validate-env.ts",
    "build:local": "pnpm with-env-local vp build",
    "prebuild:preview": "pnpm with-env-preview jiti ./scripts/validate-env.ts",
    "build:preview": "pnpm with-env-preview vp build ",
    "prebuild:production": "pnpm with-env-production jiti ./scripts/validate-env.ts",
    "build:production": "pnpm with-env-production vp build",
    "serve:local": "pnpm with-env-local vp preview",
    "test": "vitest run",
    "clean": "git clean -xdf node_modules dist .cache .wrangler",
    "with-env-local": "dotenvx run  -f ../../.env.local -f ../../.env -- ",
    "with-env-preview": "dotenvx run  -f ../../.env -- ",
    "with-env-production": "dotenvx run  -f ../../.env.production -- ",
    "wrangler": "wrangler",
    "cf-typegen": "wrangler types --env-interface Env"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/raleway": "^5.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@rectangular-labs/api": "workspace:*",
    "@rectangular-labs/auth": "workspace:*",
    "@rectangular-labs/ui": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-router": "^1.168.8",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-router-ssr-query": "^1.166.10",
    "@tanstack/react-start": "^1.167.13",
    "arktype": "catalog:",
    "motion": "^12.38.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.15.2",
    "@rectangular-labs/typescript": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "jiti": "^2.5.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-mkcert": "^2.0.0",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.50.0"
  }
}
