{
  "extends": "@rectangular-labs/typescript/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "./worker-configuration.d.ts"],

    /* Linting */
    "noUncheckedSideEffectImports": true,
    "paths": {
      "~/*": ["./src/*"],
      "@rectangular-labs/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
