{
  "name": "@rectangular-labs/db",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./src/env.ts"
    },
    "./schema/*": {
      "types": "./dist/schema/*.d.ts",
      "default": "./src/schema/*.ts"
    }
  },
  "scripts": {
    "migrate-generate": "pnpm with-env drizzle-kit generate",
    "migrate-push": "pnpm with-env drizzle-kit migrate",
    "push": "pnpm with-env drizzle-kit push",
    "studio": "pnpm with-env drizzle-kit studio",
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "git clean -xdf .turbo node_modules dist .cache",
    "with-env": "dotenvx run -f ../../.env.local  -f ../../.env -- "
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.8",
    "arktype": "catalog:",
    "drizzle-arktype": "^0.1.3",
    "drizzle-orm": "^0.44.5",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@rectangular-labs/typescript": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "typescript": "catalog:"
  },
  "overrides": {
    "drizzle-orm": "^0.44.5"
  }
}
