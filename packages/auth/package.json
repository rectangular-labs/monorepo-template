{
  "name": "@rectangular-labs/auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/server.ts",
    "./client": "./src/client.ts",
    "./env": "./src/env.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./client": "./dist/client.mjs",
      "./env": "./dist/env.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "generate": "pnpm with-env pnpx auth generate --config ./src/generate.ts --output ../db/src/schema/auth-schema.ts --yes",
    "clean": "git clean -xdf node_modules dist .cache",
    "with-env": "dotenvx run -f ../../.env.local  -f ../../.env -- "
  },
  "dependencies": {
    "@better-auth/expo": "^1.5.6",
    "@rectangular-labs/db": "workspace:*",
    "@rectangular-labs/emails": "0.0.1",
    "@t3-oss/env-core": "catalog:",
    "arktype": "catalog:",
    "better-auth": "^1.5.6"
  },
  "devDependencies": {
    "@rectangular-labs/typescript": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
