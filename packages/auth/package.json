{
  "name": "@rectangular-labs/auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./client": "./src/client.ts",
    "./env": "./src/env.ts",
    "./server": "./src/server.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      "./client": "./dist/client.mjs",
      "./env": "./dist/env.mjs",
      "./server": "./dist/server.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "generate": "pnpm with-env pnpx @better-auth/cli generate --config ./src/generate.ts --output ../db/src/schema/auth-schema.ts",
    "clean": "git clean -xdf .turbo node_modules dist .cache",
    "with-env": "dotenvx run -f ../../.env.local  -f ../../.env -- "
  },
  "dependencies": {
    "@better-auth/expo": "^1.3.7",
    "@rectangular-labs/db": "workspace:*",
    "@t3-oss/env-core": "^0.13.8",
    "arktype": "catalog:",
    "better-auth": "^1.3.7"
  },
  "devDependencies": {
    "@rectangular-labs/typescript": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
